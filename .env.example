## Razorpay
# Public key id (safe to expose to client). If omitted, server will fall back to RAZORPAY_KEY_ID.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
# Used server-side to create orders
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
# Secret (server-side only)
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

## Supabase (server-side; use SERVICE ROLE for inserts + admin list)
# Project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# Must be the "service_role" secret key (long JWT), NOT the anon "public" key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

## Admin protection
ADMIN_PASSWORD=change-me
